# LexiFact environment variables
# Fill in the values below before starting the service.

# ── Networking ──────────────────────────────────────────────
# Host port for nginx reverse proxy (e.g. 80, 443)
NGINX_PORT=

# ── Authentication ──────────────────────────────────────────
# Secret key for JWT signing — any random string, change in production
JWT_SECRET=

# ── LLM ─────────────────────────────────────────────────────
# LLM API base URL, OpenAI-compatible — e.g. https://api.deepseek.com
LLM_BASE_URL=https://api.deepseek.com
# LLM API key
LLM_API_KEY=
# Model name — e.g. deepseek-v4-flash, deepseek-v4-pro
LLM_MODEL=deepseek-v4-flash
# Reasoning effort: minimal / low / default / high / max
LLM_REASONING_EFFORT=default

# ── Audio Transcription (Volcengine ARK) ─────────────────────
# API key for Volcengine ARK ASR (speech recognition).
# Get from: https://console.volcengine.com/speech/new/setting/apikeys
VOICE_ARK_API_KEY=

# ── Midscene (UI Automation) ─────────────────────────────────
# Base URL for the vision model API (OpenAI-compatible).
# e.g. https://ark.cn-beijing.volces.com/api/v3
MIDSCENE_MODEL_BASE_URL=
# API key for the vision model
MIDSCENE_MODEL_API_KEY=
# Model name, e.g. doubao-seed-2-1-turbo-260628
MIDSCENE_MODEL_NAME=
# Model family, e.g. doubao-seed
MIDSCENE_MODEL_FAMILY=
# Extra JSON body params, e.g. {"service_tier":"fast"}
MIDSCENE_MODEL_EXTRA_BODY_JSON=

# ── MinerU (Document Parsing) ───────────────────────────────
# MinerU document parsing API Bearer token.
# Get from: https://mineru.net/apiManage/docs
MINERU_TOKEN=

# ── License ─────────────────────────────────────────────────
# License activation key
LICENSE_KEY=
